---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <generator uri="https://jekyllrb.com/" version="{{ jekyll.version }}">Jekyll</generator>
  <link href="{{ "/rtfm-feed.xml" | absolute_url }}" rel="self" type="application/atom+xml" />
  <link href="{{ "/rtfm/" | absolute_url }}" rel="alternate" type="text/html" />
  <updated>{{ site.time | date_to_xmlschema }}</updated>
  <id>{{ "/rtfm-feed.xml" | absolute_url }}</id>
  <title type="html">{{ site.title | smartify }} — RTFM</title>
  <subtitle>Long-form, technical, reference-grounded security best practices.</subtitle>
  <author>
    <name>{{ site.author.name }}</name>
  </author>
  {% assign articles = site.rtfm | sort: 'date' | reverse %}
  {% for article in articles limit: 20 %}
  <entry>
    <title type="html">{{ article.title | smartify | xml_escape }}</title>
    <link href="{{ article.url | absolute_url }}" rel="alternate" type="text/html" title="{{ article.title | smartify | xml_escape }}" />
    <published>{{ article.date | date_to_xmlschema }}</published>
    <updated>{{ article.date | date_to_xmlschema }}</updated>
    <id>{{ article.url | absolute_url }}</id>
    <content type="html" xml:base="{{ article.url | absolute_url }}">{{ article.content | xml_escape }}</content>
    {% if article.summary %}<summary type="html">{{ article.summary | xml_escape }}</summary>{% endif %}
    <author>
      <name>{{ site.author.name }}</name>
    </author>
  </entry>
  {% endfor %}
</feed>
